<UserControl x:Class="Apex.Views.StructureView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Apex.Views"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="300"
             Background="#181825">

    <UserControl.Resources>
        <local:IndentConverter x:Key="IndentConverter" />

        <Style x:Key="TreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#CDD6F4" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="2,2" />
            <Setter Property="IsExpanded" Value="True" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <Border x:Name="PART_Header"
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True"
                                    MinHeight="28">
                                <StackPanel Orientation="Horizontal">
                                    <Path x:Name="ExpandIcon"
                                          Width="10" Height="10" Margin="4,0,4,0"
                                          Fill="#6C7086" Data="M0,0 L8,4 L0,8 Z"
                                          Visibility="Collapsed"
                                          RenderTransformOrigin="0.5,0.5">
                                        <Path.RenderTransform>
                                            <RotateTransform Angle="90" />
                                        </Path.RenderTransform>
                                    </Path>
                                    <ContentPresenter x:Name="PART_HeaderContent"
                                                      Content="{TemplateBinding Header}"
                                                      ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                      ContentStringFormat="{TemplateBinding HeaderStringFormat}"
                                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                </StackPanel>
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost" Grid.Row="1" Visibility="Collapsed" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="True">
                                <Setter TargetName="ExpandIcon" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandIcon" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="90" />
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PART_Header" Property="Background" Value="#45475A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <HierarchicalDataTemplate DataType="{x:Type local:FileTreeItem}"
                                  ItemsSource="{Binding Children}">
            <Border x:Name="ItemBorder"
                    Background="Transparent"
                    Padding="4,2">
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem x:Name="CtxOpen" Header="Open" Click="CtxOpen_Click" />
                        <MenuItem x:Name="CtxFindOnBoard" Header="Find on board" Click="CtxFindOnBoard_Click" />
                        <MenuItem x:Name="CtxCopyAsTemplate" Header="Copy as template" Click="CtxCopyAsTemplate_Click"/>
                        <MenuItem x:Name="CtxCreateCard" Header="⚠ Create card" Click="CtxCreateCard_Click" />
                        <Separator x:Name="CtxSep0" />
                        <MenuItem x:Name="CtxNewNoteHere" Header="New note here" Click="CtxNewNoteHere_Click" Visibility="Collapsed" />
                        <MenuItem x:Name="CtxNewSubfolder" Header="New subfolder" Click="CtxNewSubfolder_Click" />
                        <Separator x:Name="CtxSep1" />
                        <MenuItem x:Name="CtxRename" Header="Rename" Click="CtxRename_Click" />
                        <MenuItem x:Name="CtxOpenExternal" Header="Open in system editor" Click="CtxOpenExternal_Click" />
                        <MenuItem x:Name="CtxDelete" Header="Delete" Click="CtxDelete_Click" />
                    </ContextMenu>
                </Border.ContextMenu>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Rectangle Width="{Binding Depth, Converter={StaticResource IndentConverter}}"
                               Height="1" Fill="Transparent" />
                    <TextBlock x:Name="IconText"
                               FontSize="12" Width="18"
                               TextAlignment="Center"
                               Foreground="#6C7086" />
                    <TextBlock x:Name="MissingCardIcon"
                               Text="⚠"
                               FontSize="11"
                               Foreground="#E24B4A"
                               Margin="2,0,3,0"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"
                               ToolTip="No board card — right-click to create one" />
                    <TextBlock x:Name="FileNameText"
                               Text="{Binding DisplayName}"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Margin="4,0,0,0" />
                    <Border x:Name="CategoryBadge"
                            Background="{Binding CategoryColor, FallbackValue=Transparent}"
                            CornerRadius="3" Padding="4,1" Margin="6,0,0,0"
                            Visibility="Collapsed">
                        <TextBlock Text="{Binding CategoryName}"
                                   FontSize="10" Foreground="White" FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
            </Border>
            <HierarchicalDataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsFolder}" Value="True">
                    <Setter TargetName="IconText" Property="Text" Value="&#x1F4C1;" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsFolder}" Value="True">
                    <Setter TargetName="CtxCopyAsTemplate" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsFolder}" Value="False">
                    <Setter TargetName="IconText" Property="Text" Value="&#x1F4C4;" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HasCategory}" Value="True">
                    <Setter TargetName="CategoryBadge" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter TargetName="ItemBorder" Property="Background" Value="#45475A" />
                </DataTrigger>
                <!-- MissingCard — pokaż ikonkę i czerwoną nazwę -->
                <DataTrigger Binding="{Binding MissingCard}" Value="True">
                    <Setter TargetName="MissingCardIcon" Property="Visibility" Value="Visible" />
                    <Setter TargetName="FileNameText" Property="Foreground" Value="#E24B4A" />
                    <Setter TargetName="CtxCreateCard" Property="Visibility" Value="Visible" />
                    <Setter TargetName="CtxFindOnBoard" Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding MissingCard}" Value="False">
                    <Setter TargetName="CtxCreateCard" Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <!-- Folder vs file context menu -->
                <DataTrigger Binding="{Binding IsFolder}" Value="True">
                    <Setter TargetName="CtxFindOnBoard" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="CtxSep0" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="CtxCreateCard" Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsFolder}" Value="False">
                    <Setter TargetName="CtxNewSubfolder" Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </HierarchicalDataTemplate.Triggers>
        </HierarchicalDataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#11111B" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="FILES" FontSize="11" 
                   FontWeight="SemiBold" Foreground="#6C7086" 
                   VerticalAlignment="Center"/>
                <Button x:Name="OpenFolderButton" Grid.Column="1"
                BorderThickness="0"
                Cursor="Hand" ToolTip="Open project folder"
                Click="OpenFolderButton_Click"
                Width="24" Height="24">
                    <Button.Style>
                        <Style TargetType="Button">
                            <!-- 1. Domyślny stan jest przezroczysty -->
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <!-- 2. Border, który renderuje tło i daje lekkie zaokrąglenie rogów -->
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- 3. Nadpisanie systemowego hovera -->
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <!-- Tutaj wpisz swój wymarzony kolor po najechaniu myszką -->
                                                <Setter Property="Background" Value="#222230"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>

                    <TextBlock Text="📁" FontSize="14" 
                       FontFamily="Segoe UI Emoji"
                       VerticalAlignment="Center"
                       Foreground="#707064"
                       HorizontalAlignment="Center"/>
                </Button>
            </Grid>
        </Border>

        <TreeView x:Name="FileTree"
                  Grid.Row="1"
                  Background="Transparent"
                  BorderThickness="0"
                  Foreground="#CDD6F4"
                  FontSize="13"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                  ItemContainerStyle="{StaticResource TreeItemStyle}"
                  PreviewMouseLeftButtonDown="FileTree_PreviewMouseLeftButtonDown" />
    </Grid>
</UserControl>