<UserControl x:Class="Apex.Views.NoteViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="600"
             Background="#1E1E2E"
             Foreground="#CDD6F4"
             FontFamily="Segoe UI, sans-serif"
             TextElement.FontSize="14"
             PreviewKeyDown="UserControl_PreviewKeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <!-- External-change banner -->
            <RowDefinition Height="Auto" />
            <!-- Toolbar -->
            <RowDefinition Height="Auto" />
            <!-- Content area -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════
             EXTERNAL CHANGE BANNER
             ════════════════════════════════════════ -->
        <Border x:Name="ExternalChangeBanner"
                Grid.Row="0"
                Background="#F9E2AF"
                Padding="12,6"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="This file was modified externally."
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#1E1E2E"
                           VerticalAlignment="Center" />

                <Button Grid.Column="1"
                        x:Name="LoadExternalButton"
                        Content="Load external"
                        FontSize="11"
                        Padding="8,2"
                        Margin="8,0,4,0"
                        Cursor="Hand"
                        Background="#45475A"
                        Foreground="#CDD6F4"
                        BorderThickness="0"
                        Click="LoadExternalButton_Click" />

                <Button Grid.Column="2"
                        x:Name="KeepMineButton"
                        Content="Keep mine"
                        FontSize="11"
                        Padding="8,2"
                        Cursor="Hand"
                        Background="#45475A"
                        Foreground="#CDD6F4"
                        BorderThickness="0"
                        Click="KeepMineButton_Click" />
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════
             TOOLBAR — READ MODE
             ════════════════════════════════════════ -->
        <Border x:Name="ReadToolbar"
                Grid.Row="1"
                Background="#181825"
                BorderBrush="#313244"
                BorderThickness="0,0,0,1"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <TextBlock x:Name="NoteTitle"
                           Grid.Column="0"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="#CDD6F4"
                           VerticalAlignment="Center" />

                <!-- Spacer -->
                <Rectangle Grid.Column="1" Fill="Transparent" />

                <!-- Category badge -->
                <Border x:Name="CategoryBadge"
                        Grid.Column="2"
                        CornerRadius="3"
                        Padding="6,2"
                        Margin="0,0,8,0"
                        Visibility="Collapsed"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="CategoryNameText"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="White" />
                </Border>

                <!-- Dates -->
                <TextBlock Grid.Column="3"
                           FontSize="11"
                           Foreground="#6C7086"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0">
                    <Run Text="Created:" />
                    <Run x:Name="CreationDateText" Text="—" />
                    <Run Text="  " />
                    <Run Text="Modified:" />
                    <Run x:Name="ModifiedDateText" Text="—" />
                </TextBlock>

                <!-- Edit button -->
                <Button x:Name="EditButton"
                        Grid.Column="4"
                        Content="Edit"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Padding="10,4"
                        MinWidth="60"
                        Cursor="Hand"
                        Background="#313244"
                        Foreground="#CDD6F4"
                        BorderThickness="1"
                        BorderBrush="#45475A"
                        Click="EditButton_Click" />
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════
             TOOLBAR — EDIT MODE
             ════════════════════════════════════════ -->
        <Border x:Name="EditToolbar"
                Grid.Row="1"
                Background="#181825"
                BorderBrush="#313244"
                BorderThickness="0,0,0,1"
                Padding="12,6"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Editable title -->
                <TextBox x:Name="EditTitleBox"
                         Grid.Column="0"
                         FontSize="16"
                         FontWeight="Bold"
                         Foreground="#CDD6F4"
                         Background="#313244"
                         BorderBrush="#45475A"
                         BorderThickness="1"
                         Padding="6,2"
                         Margin="0,0,8,0"
                         VerticalAlignment="Center"
                         AcceptsReturn="False"
                         CaretBrush="#CDD6F4" />

                <!-- Save button -->
                <Button x:Name="SaveButton"
                        Grid.Column="1"
                        Content="Save"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Padding="10,4"
                        MinWidth="60"
                        Margin="0,0,4,0"
                        Cursor="Hand"
                        Background="#1D9E75"
                        Foreground="White"
                        BorderThickness="0"
                        Click="SaveButton_Click" />

                <!-- Cancel button -->
                <Button x:Name="CancelButton"
                        Grid.Column="2"
                        Content="Cancel"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Padding="10,4"
                        MinWidth="60"
                        Cursor="Hand"
                        Background="#313244"
                        Foreground="#CDD6F4"
                        BorderThickness="1"
                        BorderBrush="#45475A"
                        Click="CancelButton_Click" />
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════
             CONTENT — READ MODE (FlowDocument viewer)
             ════════════════════════════════════════ -->
        <FlowDocumentScrollViewer x:Name="ReadContent"
                                  Grid.Row="2"
                                  Background="#1E1E2E"
                                  BorderThickness="0"
                                  Padding="16,12"
                                  FontSize="14"
                                  Foreground="#CDD6F4"
                                  VerticalScrollBarVisibility="Auto"
                                  IsToolBarVisible="False">
            <FlowDocumentScrollViewer.Resources>
                <!-- Default style for FlowDocument inline elements -->
                <Style TargetType="Paragraph">
                    <Setter Property="Margin" Value="0,0,0,8" />
                    <Setter Property="Foreground" Value="#CDD6F4" />
                </Style>
                <Style TargetType="Run">
                    <Setter Property="Foreground" Value="#CDD6F4" />
                </Style>
                <Style TargetType="Hyperlink">
                    <Setter Property="Foreground" Value="#89B4FA" />
                    <Setter Property="TextDecorations" Value="Underline" />
                    <Setter Property="Cursor" Value="Hand" />
                </Style>
                <Style TargetType="Section">
                    <Setter Property="Margin" Value="0" />
                </Style>
            </FlowDocumentScrollViewer.Resources>
        </FlowDocumentScrollViewer>

        <!-- ════════════════════════════════════════
             CONTENT — EDIT MODE (plain text editor)
             ════════════════════════════════════════ -->
        <TextBox x:Name="EditContent"
                 Grid.Row="2"
                 FontFamily="Consolas"
                 FontSize="13"
                 Foreground="#CDD6F4"
                 Background="#181825"
                 BorderThickness="0"
                 Padding="16,12"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 Visibility="Collapsed"
                 SpellCheck.IsEnabled="False"
                 CaretBrush="#CDD6F4" />
    </Grid>
</UserControl>