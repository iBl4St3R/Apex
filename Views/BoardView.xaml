<UserControl x:Class="Apex.Views.BoardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="#181825"
             PreviewKeyDown="BoardView_PreviewKeyDown"
             PreviewMouseLeftButtonDown="BoardView_PreviewMouseLeftButtonDown"
             PreviewMouseMove="BoardView_PreviewMouseMove"
             PreviewMouseLeftButtonUp="BoardView_PreviewMouseLeftButtonUp"
             PreviewMouseWheel="BoardView_PreviewMouseWheel">

    <Grid>
        <Border x:Name="CanvasContainer"
                ClipToBounds="True"
                Background="#181825"
                Focusable="True">

            <Canvas x:Name="CanvasTransformHost"
                    Background="Transparent"
                    Width="10000" Height="10000"
                    MouseDown="CanvasTransformHost_MouseDown"
                    MouseMove="CanvasTransformHost_MouseMove"
                    MouseUp="CanvasTransformHost_MouseUp"
                    MouseRightButtonUp="CanvasTransformHost_MouseRightButtonUp"
                    RenderTransformOrigin="0,0">

                <Canvas.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="ZoomTransform" ScaleX="1" ScaleY="1"/>
                        <TranslateTransform x:Name="PanTransform" X="0" Y="0"/>
                    </TransformGroup>
                </Canvas.RenderTransform>

                <!-- Subtle canvas boundary -->
                <Border Canvas.Left="0" Canvas.Top="0"
        Width="10000" Height="10000"
        BorderBrush="#2A2A3E"
        BorderThickness="2"
        Background="Transparent"
        IsHitTestVisible="False"/>

                <Canvas x:Name="BoardCanvas"
                        Width="10000" Height="10000"
                        Background="Transparent"/>
            </Canvas>
        </Border>
    </Grid>
</UserControl>