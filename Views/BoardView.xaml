<UserControl x:Class="Apex.Views.BoardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="#181825"
             PreviewKeyDown="BoardView_PreviewKeyDown"
             PreviewMouseLeftButtonDown="BoardView_PreviewMouseLeftButtonDown"
             PreviewMouseMove="BoardView_PreviewMouseMove"
             PreviewMouseLeftButtonUp="BoardView_PreviewMouseLeftButtonUp"
             PreviewMouseWheel="BoardView_PreviewMouseWheel">

    <Grid>
        <Border x:Name="CanvasContainer"
                ClipToBounds="True"
                Background="#181825"
                Focusable="True">

            <Grid x:Name="CanvasTransformHost"
                  RenderTransformOrigin="0,0"
                  Width="10000"
                  Height="10000"
                  MouseDown="CanvasTransformHost_MouseDown"
                  MouseMove="CanvasTransformHost_MouseMove"
                  MouseUp="CanvasTransformHost_MouseUp"
                  ContextMenuOpening="CanvasContainer_ContextMenuOpening">

                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="ZoomTransform" ScaleX="1" ScaleY="1" />
                        <TranslateTransform x:Name="PanTransform" X="0" Y="0" />
                    </TransformGroup>
                </Grid.RenderTransform>

                <Canvas x:Name="BoardCanvas" Width="10000" Height="10000">
                    <!-- Cards are added dynamically here -->
                </Canvas>
            </Grid>
        </Border>

        <!-- Reset view button overlay (top-right) -->
        <Button x:Name="ResetViewButton"
                Content="&#x2302; Reset view"
                FontSize="11"
                FontWeight="SemiBold"
                Padding="6,3"
                Cursor="Hand"
                Background="#313244"
                Foreground="#A6ADC8"
                BorderThickness="1"
                BorderBrush="#45475A"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,6,6,0"
                ToolTip="Reset view (Ctrl+Home)"
                Click="ResetViewButton_Click" />
    </Grid>
</UserControl>